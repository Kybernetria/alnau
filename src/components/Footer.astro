---
import fs from 'node:fs';
const configPath = new URL('../../site-config.json', import.meta.url);
let siteData = {
  name: 'Augusta Lykke Nau',
  tagline: 'Cybernetician. Engineer. Researcher.',
  email: 'hello@alnau.com',
  socials: { github: '#', linkedin: '#', kybernetria: '#' }
} as any;
try { siteData = JSON.parse(fs.readFileSync(configPath, 'utf8')); } catch(e) {}
const year = new Date().getFullYear();
---

<footer class="bg-base border-t border-stroke mt-auto">
  <div class="container grid grid-cols-1 md:grid-cols-2 gap-12 border-b border-stroke" style="padding: 4.5rem 0 2.5rem;">
    <div class="flex flex-col items-start">
      <!-- PLACEHOLDER: owner name -->
      <h2 class="serif-italic text-body" style="font-size: 1.1rem; margin-bottom: 0.25rem;">{siteData.name}</h2>
      <!-- PLACEHOLDER: tagline -->
      <p class="font-sans font-light text-subtle" style="font-size: 0.9rem; margin-bottom: 1.5rem;">{siteData.tagline}</p>
      <a href={`mailto:${siteData.email}`} class="btn-primary">Get in touch <span>→</span></a>
    </div>
    <div class="flex flex-col gap-2 md:items-end">
      <a href={siteData.socials.kybernetria} target="_blank" rel="noopener" class="font-sans font-normal text-subtle hover:text-body transition-colors duration-150" style="font-size: 0.875rem; display: flex; align-items: center; justify-content: space-between; width: 10rem;">
        Kybernetria.com <span>↗</span>
      </a>
      <a href={siteData.socials.github} target="_blank" rel="noopener" class="font-sans font-normal text-subtle hover:text-body transition-colors duration-150" style="font-size: 0.875rem; display: flex; align-items: center; justify-content: space-between; width: 10rem;">
        GitHub <span>↗</span>
      </a>
      <a href={siteData.socials.linkedin} target="_blank" rel="noopener" class="font-sans font-normal text-subtle hover:text-body transition-colors duration-150" style="font-size: 0.875rem; display: flex; align-items: center; justify-content: space-between; width: 10rem;">
        LinkedIn <span>↗</span>
      </a>
    </div>
  </div>
  <div class="container flex items-center font-mono text-subtle" style="padding: 1.25rem 0; font-size: 0.7rem; letter-spacing: 0.04em;">
    <div class="flex flex-col md:flex-row justify-between w-full gap-2">
      <span>© {year} {siteData.name}</span>
      <span class="hidden md:inline" style="opacity: 0.6;">CC BY-NC-SA 4.0</span>
      <span>alnau.com</span>
    </div>
  </div>
</footer>
