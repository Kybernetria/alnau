---
import config from '../../site-config.json';
const defaultData = {
  name: 'Augusta Lykke Nau',
  tagline: 'Cybernetician. Engineer. Agentic Builder.',
  email: 'hello@alnau.com',
  socials: { github: '#', linkedin: '#', kybernetria: '#' }
};
const siteData = { ...defaultData, ...config };
const year = new Date().getFullYear();
---

<footer class="bg-base border-t border-stroke mt-auto">
  <div class="container border-b border-stroke" style="padding-top: 4.5rem; padding-bottom: 2.5rem;">
    <div class="grid gap-12" style="grid-template-columns: 1fr; ">
      <div class="flex flex-col items-start">
        <h2 class="serif-italic text-body" style="font-size: 1.1rem; margin-bottom: 0.25rem;">{siteData.name}</h2>
        <p class="font-sans font-light text-subtle" style="font-size: 0.9rem; margin-bottom: 1.5rem;">{siteData.tagline}</p>
        <a href={`mailto:${siteData.email}`} class="btn-primary">Get in touch <span>→</span></a>
      </div>
      <div class="flex flex-row flex-wrap gap-x-6 gap-y-2">
        <a href={siteData.socials.kybernetria} target="_blank" rel="noopener" class="font-sans font-normal text-subtle hover:text-body transition-colors duration-150" style="font-size: 0.875rem;">
          Kybernetria.com ↗
        </a>
        <a href={siteData.socials.github} target="_blank" rel="noopener" class="font-sans font-normal text-subtle hover:text-body transition-colors duration-150" style="font-size: 0.875rem;">
          GitHub ↗
        </a>
        <a href={siteData.socials.linkedin} target="_blank" rel="noopener" class="font-sans font-normal text-subtle hover:text-body transition-colors duration-150" style="font-size: 0.875rem;">
          LinkedIn ↗
        </a>
      </div>
    </div>
  </div>
  <div class="container" style="padding-top: 1.25rem; padding-bottom: 1.25rem;">
    <div class="flex flex-wrap justify-between gap-x-4 gap-y-1 font-mono text-subtle" style="font-size: 0.7rem; letter-spacing: 0.04em;">
      <span>© {year} {siteData.name}</span>
      <span style="opacity: 0.6;">CC BY-NC-SA 4.0</span>
      <span>alnau.com</span>
    </div>
  </div>
</footer>
