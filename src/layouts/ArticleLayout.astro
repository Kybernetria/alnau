---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;
const formattedDate = frontmatter.date
  ? new Date(frontmatter.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
  : '';
---

<BaseLayout title={`${frontmatter.title} — Augusta Lykke Nau`}>
  <Navbar />
  <main class="container min-h-screen" style="padding-top: 7rem; padding-bottom: 5rem;">
    <article style="max-width: 65ch; margin: 0 auto;">
      <header class="border-b border-stroke" style="margin-bottom: 4rem; padding-bottom: 2rem;">
        <div class="flex justify-between items-center" style="margin-bottom: 1.5rem;">
          <span class="mono text-subtle" style="font-size: 0.7rem;">{formattedDate}</span>
          <span class="label border border-stroke" style="border-radius: 2px; padding: 0.2rem 0.5rem;">{frontmatter.tag}</span>
        </div>
        <h1 class="serif-italic text-body" style="font-size: clamp(2rem, 5vw, 4rem); line-height: 1.05; letter-spacing: -0.01em; overflow-wrap: break-word;">{frontmatter.title}</h1>
      </header>
      <div class="article-body text-body"><slot /></div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .article-body { font-family: var(--font-sans); font-weight: 300; line-height: 1.65; }
  .article-body p { margin-bottom: 1.5em; }
  .article-body h2 { font-family: var(--font-serif); margin-top: 2.5em; margin-bottom: 1em; font-size: 2.2rem; color: var(--color-body); line-height: 1.1; }
  .article-body h3 { font-family: var(--font-serif); margin-top: 2em; margin-bottom: 0.75em; font-size: 1.7rem; color: var(--color-body); line-height: 1.2; }
  .article-body a { color: var(--color-body); text-decoration: underline; text-decoration-color: var(--color-prussian); text-underline-offset: 3px; transition: color 150ms ease; }
  .article-body a:hover { color: var(--color-steel); text-decoration-color: var(--color-steel); }
  .article-body ul, .article-body ol { margin-bottom: 1.5em; padding-left: 1.5em; }
  .article-body li { margin-bottom: 0.5em; }
  .article-body blockquote { border-left: 2px solid var(--color-stroke); padding-left: 1.5em; margin: 1.5em 0; color: var(--color-subtle); }
</style>
